# Auro CLI environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# GitHub Personal Access Token.
# - Required by `auro ado` (read GitHub issues, update GitHub project field).
# - Required by `auro version-scan` (list repos in the target org, fetch
#   each package.json, and detect archived Auro source repos in
#   AlaskaAirlines).
# - Required by `auro version-tickets` to inline CHANGELOG slices into
#   ticket bodies. Without it, tickets fall back to a plain CHANGELOG link.
GH_TOKEN=

# Azure DevOps Personal Access Token for the `itsals` org.
# - Required by `auro ado` to create work items.
# - Required by `auro version-tickets --apply` to create work items.
# Scopes needed: Work Items > Read, write, & manage.
# Generate at: https://dev.azure.com/itsals/_usersSettings/tokens
ADO_TOKEN=

# Default GitHub org for `auro version-scan` to crawl.
# Optional — defaults to Alaska-ECommerce when unset.
# The `--org <name>` CLI flag overrides this value when both are set.
ECOM_ORG=Alaska-ECommerce
